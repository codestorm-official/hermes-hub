# Core app config
APP_AUTHOR=Asep Saputra
APP_NAME=Hermes
APP_URL=https://hermes.example.com
DATA_DIR=/app/data
HERMES_TOKEN=change-me-to-a-long-random-token
HOST_PORT=3000
LOG_LEVEL=info
TRUST_PROXY=true

# Optional LLM bootstrap config
# You can leave these empty and configure LLM from the dashboard Settings menu.
# Dashboard settings are persisted in /app/data/settings.json and override these defaults.
LLM_PROVIDER=
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_MAX_CONTEXT_NOTES=6

# Channel settings such as Telegram bot tokens are configured from the dashboard.
# They are persisted in /app/data/settings.json.
